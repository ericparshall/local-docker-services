# Copy to .env and adjust as needed:
#   cp .env.example .env

# Host port (static project assignment — NOT the image default 8080)
# Canonical map: ../../PORTS.md
SIGNAL_HOST_PORT=18701

# Packaging image variant:
#   jre    - JVM (default; more compatible)
#   native - GraalVM native binary (faster, sometimes flakier)
SIGNAL_VARIANT=jre

# Docker image tag for registry.gitlab.com/packaging/signal-cli/signal-cli-<variant>
SIGNAL_IMAGE_TAG=latest
