# Copy to .env and adjust as needed:
#   cp .env.example .env

# Host port (static project assignment — NOT the image default 8080)
# Canonical map: ../../PORTS.md
SIGNAL_HOST_PORT=18701

# Docker image tag (default: latest)
SIGNAL_IMAGE_TAG=latest

# Runtime mode for signal-cli-rest-api
#   native  - recommended for performance (GraalVM native)
#   normal  - JVM mode, more compatible
#   json-rpc - JSON-RPC daemon mode
SIGNAL_MODE=native

# Optional: cron schedule for auto-receive (leave empty / omit to disable)
# Example: every day at 22:00
# SIGNAL_AUTO_RECEIVE_SCHEDULE=0 22 * * *
